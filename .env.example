# ── Supabase CLI (uso local con ``npx supabase``; ver DATABASE.md) ────────────
# SUPABASE_ACCESS_TOKEN=   # dashboard → Account → Access tokens → link / db push

# ── PostgreSQL (opcional — read-through y workers; ver DATABASE.md) ─────────
# Docker Compose:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/climatifai
# Postgres en Mac (Homebrew; usuario = resultado de ``whoami``):
# DATABASE_URL=postgresql+asyncpg://TU_USUARIO_MAC@localhost:5432/climatifai

# ── Artefactos en disco (HF / snapshots grandes) ────────────────────────────
ARTIFACT_STORAGE_ROOT=./data/artifacts
QDRANT_URL=http://localhost:6333
OPENMETEO_CACHE_MAX_AGE_SEC=86400
ADVISOR_CACHE_MAX_AGE_SEC=86400
FIRMS_CACHE_MAX_AGE_SEC=900

# ── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── NASA FIRMS (register free at earthdata.nasa.gov) ──────────────────────
FIRMS_API_KEY=your_firms_key_here

# ── Climate data providers (plug in the one you choose) ────────────────────
# Open-Meteo — free, no key needed for public API
OPEN_METEO_BASE_URL=https://archive-api.open-meteo.com/v1

# NASA POWER — free, no key needed
NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api/temporal/monthly/point

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── App ────────────────────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO
